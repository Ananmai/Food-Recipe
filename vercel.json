{
  "version": 2,
  "builds": [
    {
      "src": "recipe_api/wsgi.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "recipe_api/wsgi.py" },
    { "src": "/admin/(.*)", "dest": "recipe_api/wsgi.py" },
    { "src": "/assets/(.*)", "dest": "frontend/assets/$1" },
    { "src": "/static/(.*)", "dest": "frontend/$1" },
    { "src": "/(.*)", "dest": "frontend/index.html" }
  ]
}
